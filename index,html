<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redes de Computadoras 2025 - Plataforma Interactiva</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- Chosen Palette: Indigo and Slate Theme (Slate-50 for background, Indigo-600 for primary actions, Slate-800 for text, Teal-500 for accents) -->
    <!-- Application Structure Plan: The application uses a dashboard-style SPA layout designed to transform a static syllabus into an exploratory tool. It features a sidebar navigation dividing content into three functional views: 1. 'Visión General' (Dashboard) provides high-level context, metadata (professor, period), and a visual breakdown of the course weight using a chart. 2. 'Explorador del Temario' (Unit Explorer) utilizes a master-detail pattern, preventing cognitive overload by allowing users to click a unit to reveal its specific subtopics dynamically. 3. 'Conexiones Clave' (Interactive Map) synthesizes concepts from Unit 2 (OSI) and Unit 3 (Devices) into a clickable matrix, enabling active learning by exploring relationships. -->
    <!-- Visualization & Content Choices: Report Info: Syllabus structure -> Goal: Inform & Organize -> Viz: Doughnut Chart (Chart.js) -> Interaction: Hover for details -> Justification: Provides an immediate visual understanding of the 5 units' composition. Report Info: Detailed topics -> Goal: Organize -> Viz: Interactive Master-Detail list (HTML/JS) -> Interaction: Click to expand -> Justification: Makes a dense 27-item list easily navigable. Report Info: OSI Layers & Devices -> Goal: Relationships -> Viz: Interactive HTML Grid -> Interaction: Click layer to highlight devices -> Justification: Transforms static concepts into an exploratory learning exercise. Confirming NO SVG/Mermaid used. -->
    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc; 
        }
        
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            height: 40vh;
            max-height: 350px;
        }

        .view-section {
            display: none;
            animation: fadeIn 0.4s ease-in-out;
        }

        .view-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .nav-item.active {
            background-color: #e0e7ff;
            color: #4f46e5;
            font-weight: 600;
            border-right: 4px solid #4f46e5;
        }

        .unit-card {
            transition: all 0.2s;
        }
        
        .unit-card.selected {
            border-color: #4f46e5;
            background-color: #f5f3ff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .layer-btn.active-layer {
            background-color: #4f46e5;
            color: white;
        }

        .device-box {
            transition: all 0.3s ease;
            opacity: 0.5;
            transform: scale(0.95);
        }

        .device-box.highlight {
            opacity: 1;
            transform: scale(1.05);
            border-color: #10b981;
            background-color: #ecfdf5;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="text-slate-800 h-screen flex flex-col md:flex-row overflow-hidden">

    <nav class="w-full md:w-64 bg-white border-r border-slate-200 flex flex-col shadow-sm z-10 flex-shrink-0">
        <div class="p-6 border-b border-slate-200">
            <div class="text-2xl mb-2">🌐</div>
            <h1 class="font-bold text-lg text-indigo-900 leading-tight">Redes de Computadoras</h1>
            <p class="text-xs text-slate-500 mt-1 font-mono">SCD - 1021</p>
        </div>
        <div class="flex flex-row md:flex-col overflow-x-auto md:overflow-visible p-4 gap-2 flex-grow">
            <button onclick="app.navigate('dashboard')" id="nav-dashboard" class="nav-item active flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors whitespace-nowrap md:whitespace-normal">
                <span class="text-xl">📊</span>
                <span>Visión General</span>
            </button>
            <button onclick="app.navigate('temario')" id="nav-temario" class="nav-item flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors whitespace-nowrap md:whitespace-normal">
                <span class="text-xl">🗂️</span>
                <span>Explorador del Temario</span>
            </button>
            <button onclick="app.navigate('interactivo')" id="nav-interactivo" class="nav-item flex items-center gap-3 w-full text-left px-4 py-3 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors whitespace-nowrap md:whitespace-normal">
                <span class="text-xl">🔗</span>
                <span>Conexiones Clave</span>
            </button>
        </div>
        <div class="hidden md:block p-6 border-t border-slate-200 bg-slate-50 text-xs text-slate-500">
            Tecnológico Nacional de México<br>ITSNCG
        </div>
    </nav>

    <main class="flex-1 h-full overflow-y-auto bg-slate-50 p-4 md:p-8 relative">

        <section id="view-dashboard" class="view-section active max-w-5xl mx-auto">
            <header class="mb-8">
                <h2 class="text-3xl font-bold text-slate-900 mb-2">Visión General del Curso</h2>
                <p class="text-slate-600 text-lg">Esta sección proporciona un resumen ejecutivo del programa de la asignatura. Aquí podrás entender la estructura general del curso, su peso académico distribuido en 5 unidades fundamentales y los datos de identificación del periodo lectivo, diseñados para preparar a los estudiantes en la arquitectura y administración de redes LAN.</p>
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 flex flex-col justify-center">
                    <span class="text-sm text-slate-500 uppercase tracking-wider font-semibold mb-1">Titular de la Materia</span>
                    <span class="text-xl font-bold text-indigo-700">M.G.T.I Isaac Neftali Molina Cepeda</span>
                </div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 flex flex-col justify-center">
                    <span class="text-sm text-slate-500 uppercase tracking-wider font-semibold mb-1">Periodo Lectivo</span>
                    <span class="text-xl font-bold text-slate-800">Agosto - Diciembre 2025</span>
                </div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 flex flex-col justify-center">
                    <span class="text-sm text-slate-500 uppercase tracking-wider font-semibold mb-1">Total de Unidades</span>
                    <div class="flex items-baseline gap-2">
                        <span class="text-4xl font-black text-teal-500">5</span>
                        <span class="text-slate-600 font-medium">módulos temáticos</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 md:p-8">
                <h3 class="text-xl font-bold text-slate-800 mb-4 text-center">Distribución del Programa Analítico</h3>
                <p class="text-center text-slate-500 mb-6 text-sm max-w-2xl mx-auto">El siguiente gráfico ilustra la proporción de temas que conforman cada unidad del curso, mostrando el énfasis en la planificación y el diseño respecto a los fundamentos teóricos.</p>
                
                <div class="chart-container">
                    <canvas id="syllabusChart"></canvas>
                </div>
            </div>
        </section>

        <section id="view-temario" class="view-section max-w-6xl mx-auto h-full flex flex-col">
            <header class="mb-6 flex-shrink-0">
                <h2 class="text-3xl font-bold text-slate-900 mb-2">Explorador del Temario</h2>
                <p class="text-slate-600">Explora de manera interactiva el contenido detallado de las 5 unidades. Selecciona una unidad en el panel izquierdo para desplegar todos sus subtemas, competencias y estructura analítica en el panel derecho. Este formato facilita la consulta progresiva sin sobrecargar la lectura.</p>
            </header>

            <div class="flex flex-col lg:flex-row gap-6 flex-1 min-h-0">
                <div class="w-full lg:w-1/3 flex flex-col gap-3 overflow-y-auto pr-2" id="unit-list-container">
                </div>

                <div class="w-full lg:w-2/3 bg-white rounded-xl shadow-sm border border-slate-200 p-6 md:p-8 overflow-y-auto">
                    <div id="unit-detail-empty" class="h-full flex flex-col items-center justify-center text-slate-400">
                        <span class="text-6xl mb-4">👈</span>
                        <p class="text-lg font-medium">Selecciona una unidad para ver los detalles</p>
                    </div>
                    
                    <div id="unit-detail-content" class="hidden">
                        <div class="flex items-center gap-4 mb-6 pb-6 border-b border-slate-100">
                            <div id="detail-icon" class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-3xl shadow-inner">
                            </div>
                            <div>
                                <h4 id="detail-unit-num" class="text-indigo-600 font-bold tracking-wide uppercase text-sm mb-1"></h4>
                                <h3 id="detail-title" class="text-2xl font-bold text-slate-900"></h3>
                            </div>
                        </div>
                        
                        <div class="space-y-6">
                            <div>
                                <h5 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Subtemas correspondientes</h5>
                                <ul id="detail-topics" class="space-y-3">
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="view-interactivo" class="view-section max-w-5xl mx-auto">
            <header class="mb-8">
                <h2 class="text-3xl font-bold text-slate-900 mb-2">Conexiones Clave: OSI y Dispositivos</h2>
                <p class="text-slate-600 text-lg">Esta herramienta interactiva conecta los conceptos teóricos de la Unidad 2 (Modelo OSI) con el hardware práctico de la Unidad 3 (Dispositivos de Red). Haz clic en las diferentes capas del modelo OSI a la izquierda para identificar qué dispositivos operan en ese nivel específico.</p>
            </header>

            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                    
                    <div class="space-y-4">
                        <h3 class="font-bold text-slate-800 text-xl mb-4 flex items-center gap-2">
                            <span>📑</span> Unidad 2: Capas del Modelo
                        </h3>
                        <div class="flex flex-col gap-2">
                            <button onclick="app.highlightDevices('superior')" id="layer-superior" class="layer-btn w-full text-left px-6 py-4 rounded-lg border-2 border-slate-200 hover:border-indigo-400 text-slate-700 font-medium transition-all">
                                Capas Superiores (Aplicación, Presentación, Sesión)
                            </button>
                            <button onclick="app.highlightDevices('transporte')" id="layer-transporte" class="layer-btn w-full text-left px-6 py-4 rounded-lg border-2 border-slate-200 hover:border-indigo-400 text-slate-700 font-medium transition-all">
                                Capa de Transporte
                            </button>
                            <button onclick="app.highlightDevices('red')" id="layer-red" class="layer-btn w-full text-left px-6 py-4 rounded-lg border-2 border-slate-200 hover:border-indigo-400 text-slate-700 font-medium transition-all">
                                Capa de Red
                            </button>
                            <button onclick="app.highlightDevices('enlace')" id="layer-enlace" class="layer-btn w-full text-left px-6 py-4 rounded-lg border-2 border-slate-200 hover:border-indigo-400 text-slate-700 font-medium transition-all">
                                Capa de Enlace de Datos
                            </button>
                            <button onclick="app.highlightDevices('fisica')" id="layer-fisica" class="layer-btn w-full text-left px-6 py-4 rounded-lg border-2 border-slate-200 hover:border-indigo-400 text-slate-700 font-medium transition-all">
                                Capa Física
                            </button>
                        </div>
                    </div>

                    <div class="bg-slate-50 p-6 rounded-xl border border-slate-200">
                        <h3 class="font-bold text-slate-800 text-xl mb-6 flex items-center gap-2">
                            <span>🛠️</span> Unidad 3: Dispositivos de Red
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="device-box text-center p-4 rounded-lg border-2 border-slate-200 bg-white" data-layer="superior">
                                <div class="text-3xl mb-2">🛡️</div>
                                <div class="font-bold text-sm text-slate-800">Firewalls de Aplicación</div>
                                <div class="text-xs text-slate-500 mt-1">Proxies, Gateways</div>
                            </div>
                            
                            <div class="device-box text-center p-4 rounded-lg border-2 border-slate-200 bg-white" data-layer="red">
                                <div class="text-3xl mb-2">🛣️</div>
                                <div class="font-bold text-sm text-slate-800">Routers</div>
                                <div class="text-xs text-slate-500 mt-1">Switches Capa 3, Encaminadores</div>
                            </div>
                            
                            <div class="device-box text-center p-4 rounded-lg border-2 border-slate-200 bg-white" data-layer="enlace">
                                <div class="text-3xl mb-2">🔄</div>
                                <div class="font-bold text-sm text-slate-800">Switches</div>
                                <div class="text-xs text-slate-500 mt-1">Puentes (Bridges), Tarjetas NIC</div>
                            </div>

                            <div class="device-box text-center p-4 rounded-lg border-2 border-slate-200 bg-white" data-layer="fisica">
                                <div class="text-3xl mb-2">🔌</div>
                                <div class="font-bold text-sm text-slate-800">Hubs y Repetidores</div>
                                <div class="text-xs text-slate-500 mt-1">Transceptores, Cables, Conectores</div>
                            </div>
                        </div>
                        <div class="mt-6 text-center text-sm text-slate-500 italic" id="interaction-feedback">
                            Selecciona una capa en el panel izquierdo para ver la correspondencia.
                        </div>
                    </div>

                </div>
            </div>
        </section>

    </main>

    <script>
        const data = {
            units: [
                {
                    id: 1,
                    num: "Unidad 1",
                    title: "Introducción a Redes de Datos",
                    icon: "🚀",
                    desc: "Conceptos fundamentales y topologías básicas que estructuran la comunicación de datos.",
                    topics: [
                        "1.1. Orígenes y evolución",
                        "1.2. Conceptos básicos de redes",
                        "1.3. Clasificación de redes",
                        "1.4. Topologías de redes: físicas y lógicas"
                    ]
                },
                {
                    id: 2,
                    num: "Unidad 2",
                    title: "Normas y estándares de redes de datos",
                    icon: "📜",
                    desc: "Reglas internacionales que garantizan la interoperabilidad, enfocándose en OSI y TCP/IP.",
                    topics: [
                        "2.1 Modelo de Comunicación OSI",
                        "2.2 Modelo de Comunicación TCP/IP",
                        "2.3 Estándares IEEE 802",
                        "2.3.1 Estándares IEEE 802 para Redes Alámbricas",
                        "2.3.2 Estándares IEEE 802 para Redes Inalámbricas",
                        "2.4 Pilas de protocolos y flujos de datos"
                    ]
                },
                {
                    id: 3,
                    num: "Unidad 3",
                    title: "Dispositivos de red",
                    icon: "🛠️",
                    desc: "Análisis del hardware encargado de transmitir, conmutar y enrutar la información.",
                    topics: [
                        "3.1 Dispositivos de capa física",
                        "3.2 Dispositivos de capa de enlace de datos",
                        "3.3 Dispositivos de cada de red",
                        "3.4 Dispositivos de capas superiores"
                    ]
                },
                {
                    id: 4,
                    num: "Unidad 4",
                    title: "Cableado estructurado",
                    icon: "🏢",
                    desc: "Diseño e instalación de la infraestructura física que soporta las telecomunicaciones.",
                    topics: [
                        "4.1 Normas y estándares",
                        "4.2 Componentes y herramientas de Instalación",
                        "4.3 Identificación y especificaciones"
                    ]
                },
                {
                    id: 5,
                    num: "Unidad 5",
                    title: "Planificación y diseño de una red LAN",
                    icon: "📐",
                    desc: "Fase integradora para crear una red desde cero, incluyendo direccionamiento y pruebas.",
                    topics: [
                        "5.1 Memoria técnica",
                        "5.2 Análisis de necesidades y requerimientos",
                        "5.3 Diseño lógico de la red",
                        "5.3.1 Direccionamiento IP",
                        "5.4 Diseño físico de la red",
                        "5.4.1 Sistema de cable estructurado",
                        "5.4.2 Dispositivos de red",
                        "5.4.3 Servidores y estaciones de trabajo",
                        "5.4.4 Sistemas operativos de red y aplicaciones",
                        "5.4.5 Pruebas y liberación"
                    ]
                }
            ]
        };

        const app = {
            chartInstance: null,

            init() {
                this.renderUnitCards();
                this.initChart();
            },

            navigate(viewId) {
                document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
                document.getElementById('view-' + viewId).classList.add('active');

                document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
                document.getElementById('nav-' + viewId).classList.add('active');
            },

            renderUnitCards() {
                const container = document.getElementById('unit-list-container');
                container.innerHTML = '';

                data.units.forEach(unit => {
                    const card = document.createElement('button');
                    card.className = 'unit-card w-full text-left bg-white p-4 rounded-xl border border-slate-200 hover:border-indigo-400 focus:outline-none flex flex-col gap-2';
                    card.id = `unit-card-${unit.id}`;
                    card.onclick = () => this.selectUnit(unit.id);

                    card.innerHTML = `
                        <div class="flex items-center gap-3">
                            <span class="text-2xl">${unit.icon}</span>
                            <div>
                                <span class="text-xs font-bold text-indigo-500 uppercase">${unit.num}</span>
                                <h3 class="font-bold text-slate-800 leading-tight">${unit.title}</h3>
                            </div>
                        </div>
                    `;
                    container.appendChild(card);
                });
            },

            selectUnit(id) {
                document.querySelectorAll('.unit-card').forEach(card => card.classList.remove('selected'));
                document.getElementById(`unit-card-${id}`).classList.add('selected');

                document.getElementById('unit-detail-empty').classList.add('hidden');
                document.getElementById('unit-detail-content').classList.remove('hidden');

                const unit = data.units.find(u => u.id === id);
                
                document.getElementById('detail-icon').innerText = unit.icon;
                document.getElementById('detail-unit-num').innerText = unit.num;
                document.getElementById('detail-title').innerText = unit.title;

                const topicsList = document.getElementById('detail-topics');
                topicsList.innerHTML = '';
                
                unit.topics.forEach(topic => {
                    const li = document.createElement('li');
                    li.className = 'flex items-start gap-3 p-3 rounded-lg bg-slate-50 border border-slate-100';
                    li.innerHTML = `
                        <div class="mt-1 w-2 h-2 rounded-full bg-teal-400 flex-shrink-0"></div>
                        <span class="text-slate-700 leading-snug">${topic}</span>
                    `;
                    topicsList.appendChild(li);
                });
            },

            initChart() {
                const ctx = document.getElementById('syllabusChart').getContext('2d');
                
                const labels = data.units.map(u => u.num + ": " + u.title);
                const topicCounts = data.units.map(u => u.topics.length);

                this.chartInstance = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Cantidad de Subtemas',
                            data: topicCounts,
                            backgroundColor: [
                                '#818cf8', 
                                '#34d399', 
                                '#fbbf24', 
                                '#f87171', 
                                '#6366f1'  
                            ],
                            borderWidth: 2,
                            borderColor: '#ffffff',
                            hoverOffset: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    font: { family: "'Inter', sans-serif", size: 12 },
                                    color: '#475569',
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            return data.labels.map(function(label, i) {
                                                const meta = chart.getDatasetMeta(0);
                                                const ds = data.datasets[0];
                                                const value = ds.data[i];
                                                let wrappedLabel = label;
                                                if(label.length > 25) {
                                                    wrappedLabel = label.substring(0, 22) + '...';
                                                }
                                                return {
                                                    text: `${wrappedLabel} (${value} temas)`,
                                                    fillStyle: ds.backgroundColor[i],
                                                    hidden: isNaN(ds.data[i]) || meta.data[i].hidden,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                titleFont: { family: "'Inter', sans-serif", size: 13 },
                                bodyFont: { family: "'Inter', sans-serif", size: 14, weight: 'bold' },
                                padding: 12,
                                cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        let label = context.label || '';
                                        if (label) {
                                            label += ': ';
                                        }
                                        if (context.parsed !== null) {
                                            label += context.parsed + ' Subtemas';
                                        }
                                        return label;
                                    }
                                }
                            }
                        },
                        cutout: '65%'
                    }
                });
            },

            highlightDevices(layerName) {
                document.querySelectorAll('.layer-btn').forEach(btn => {
                    btn.classList.remove('active-layer');
                    btn.classList.replace('border-indigo-500', 'border-slate-200');
                });
                
                const activeBtn = document.getElementById('layer-' + layerName);
                if(activeBtn) {
                    activeBtn.classList.add('active-layer');
                }

                document.querySelectorAll('.device-box').forEach(box => {
                    box.classList.remove('highlight');
                    if (box.dataset.layer === layerName) {
                        box.classList.add('highlight');
                    }
                });

                const feedback = document.getElementById('interaction-feedback');
                const messages = {
                    'superior': 'Firewalls, Proxies y Gateways operan en la cima del modelo, gestionando sesiones y datos de aplicaciones.',
                    'transporte': '¡Aviso! El temario principal no detalla dispositivos exclusivos de Capa 4, pero aquí operan protocolos como TCP/UDP.',
                    'red': 'Routers y Switches Capa 3 (L3) enrutan paquetes basándose en direcciones IP lógicas.',
                    'enlace': 'Los Switches estándar y las tarjetas de red (NIC) conmutan tramas utilizando direcciones MAC físicas.',
                    'fisica': 'Hubs y repetidores amplifican señales eléctricas sin entender de direcciones lógicas o físicas.'
                };
                
                feedback.innerHTML = `<strong class="text-indigo-600">Observación:</strong> ${messages[layerName]}`;
                feedback.classList.remove('italic', 'text-slate-500');
                feedback.classList.add('text-slate-700');
            }
        };

        window.onload = () => {
            app.init();
        };
    </script>
</body>
</html>
